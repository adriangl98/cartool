# Environment variables for services/api
# Copy this file to .env and fill in values. Never commit .env.

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://cartool_user:CHANGE_ME@localhost:5432/cartool_dev

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── Environment tier (development | staging | production) ─────
NODE_ENV=development

# ── CORS: comma-separated list of allowed origins (production only)
# Example: https://app.cartool.io,https://admin.cartool.io
CORS_ALLOWED_ORIGINS=

# ── Financial Engine service URL
FINANCIAL_ENGINE_URL=http://financial-engine:8000
