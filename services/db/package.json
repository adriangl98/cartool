{
  "name": "@cartool/db",
  "version": "1.0.0",
  "private": true,
  "description": "Database migrations and seed scripts for the cartool platform",
  "scripts": {
    "migrate:up": "node-pg-migrate up --migrations-dir migrations --config-file node-pg-migrate.config.cjs",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --config-file node-pg-migrate.config.cjs",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations --config-file node-pg-migrate.config.cjs",
    "seed": "node scripts/seed.cjs",
    "seed:buy-rates": "node scripts/seed-buy-rates.cjs",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "node-pg-migrate": "7.6.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "globalSetup": "./tests/globalSetup.ts",
    "globalTeardown": "./tests/globalTeardown.ts"
  }
}
