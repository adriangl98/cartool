# Environment variables for services/db
# Copy this file to .env and fill in values. Never commit .env.

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://cartool_user:CHANGE_ME@localhost:5432/cartool_dev

# Used by the test suite to avoid clobbering the dev database
TEST_DATABASE_URL=postgresql://cartool_user:CHANGE_ME@localhost:5432/cartool_test
