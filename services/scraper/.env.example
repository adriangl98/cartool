# Environment variables for services/scraper
# Copy this file to .env and fill in values. Never commit .env.

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/cartool

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── Proxy pool ────────────────────────────────────────────────
# Newline-separated residential proxy list (host:port:user:pass per line).
# In shell, use $'...' syntax or a file: PROXY_LIST=$(<proxies.txt)
PROXY_LIST=proxy1.example.com:8080:user1:pass1

# ── AWS S3 (raw HTML archival) ────────────────────────────────
S3_BUCKET_NAME=cartool-raw-html
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ── Buy rates monthly refresh ──────────────────────────────────
# Absolute or relative path to the CSV file used by the monthly buy_rates
# BullMQ job. Optional — if unset the job logs a warning and skips.
# BUY_RATES_CSV_PATH=./seeds/buy_rates_april_2026.csv

# ── Server ────────────────────────────────────────────────────
PORT=3003

# ── Environment tier (development | staging | production) ─────
NODE_ENV=development
