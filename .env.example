# ============================================================
# cartool — root .env.example
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME
# Constructed from the above by docker-compose; set explicitly for external use:
DATABASE_URL=postgresql://cartool_user:CHANGE_ME@localhost:5432/cartool_dev
TEST_DATABASE_URL=postgresql://cartool_user:CHANGE_ME@localhost:5432/cartool_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME
# Constructed from the above by docker-compose; set explicitly for external use:
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── AWS S3 (raw HTML archival) ────────────────────────────────────────────────
S3_BUCKET_NAME=cartool-raw-html
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ── Auth Service ──────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=CHANGE_ME
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Scraper ───────────────────────────────────────────────────────────────────
# Comma-separated list of proxy URLs
PROXY_LIST=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080

# ── Notification Service ──────────────────────────────────────────────────────
# Example: SendGrid, Twilio, or similar
SENDGRID_API_KEY=CHANGE_ME
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME

# ── Environment tier ──────────────────────────────────────────────────────────
NODE_ENV=development
