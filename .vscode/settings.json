{
  "mcp": {
    "servers": {
      "github": {
        "command": "docker",
        "args": [
          "run",
          "-i",
          "--rm",
          "-e",
          "GITHUB_PERSONAL_ACCESS_TOKEN",
          "ghcr.io/github/github-mcp-server"
        ],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github-token}"
        }
      }
    },
    "inputs": [
      {
        "id": "github-token",
        "type": "command",
        "command": "github.copilot.ghToken"
      }
    ]
  }
}