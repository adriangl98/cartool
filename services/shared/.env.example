# Environment variables for services/shared
# Copy this file to .env and fill in values. Never commit .env.

# Redis connection string (required by all Node.js services)
# Format: redis://<user>:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# AWS S3 — blob storage for raw HTML archival
S3_BUCKET_NAME=cartool-raw-html
AWS_REGION=us-east-1
# In production these are injected via AWS Secrets Manager / IAM role; set locally only for dev/test.
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
